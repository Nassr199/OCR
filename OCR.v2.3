class WindowsColoredFormatter(logging.Formatter):
    """Professional colored formatter for Windows CMD"""
    
    LEVEL_COLORS = {
        'DEBUG': (Colors.CYAN, 'в—Ҳ'),
        'INFO': (Colors.GREEN, 'в—Ҹ'),
        'WARNING': (Colors.YELLOW, 'в–І'),
        'ERROR': (Colors.RED, 'вң–'),
        'CRITICAL': (Colors.BRIGHT_RED + Colors.BOLD, 'в–Ҳ'),
    }
    
    def format(self, record):
        color, symbol = self.LEVEL_COLORS.get(record.levelname, (Colors.WHITE, 'в—Ӣ'))
        timestamp = time.strftime('%H:%M:%S')
        level_str = f"{color}{symbol} {record.levelname:8}{Colors.RESET}"
        time_str = f"{Colors.DIM}{timestamp}{Colors.RESET}"
        msg_str = record.getMessage()
        return f"{time_str} {level_str} в”Ӯ {msg_str}"

def setup_logging(verbose: bool = False):
    """Setup enhanced logging for Windows"""
    handler = logging.StreamHandler(sys.stdout)
    handler.setFormatter(WindowsColoredFormatter())
    
    logger = logging.getLogger(__name__)
    logger.setLevel(logging.DEBUG if verbose else logging.INFO)
    logger.handlers.clear()
    logger.addHandler(handler)
    
    return logger

logger = setup_logging()

