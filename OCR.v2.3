# PARALLEL PROCESSING - Enhanced with Windows progress
# в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

def process_images_parallel(files: List[str], model, config: OCRConfig, metrics: PerformanceMetrics):
    """Enhanced parallel processing with Windows-optimized progress"""
    results = []
    total = len(files)
    
    # Update cache size if specified in config
    if config.cache_size != image_cache.max_size:
        image_cache.resize(config.cache_size)
    
    if TQDM_AVAILABLE:
        pbar = tqdm(
            total=total,
            desc=f"{Colors.CYAN}Processing{Colors.RESET}",
            unit="img",
            ncols=100,
            bar_format='{l_bar}{bar}| {n_fmt}/{total_fmt} [{elapsed}<{remaining}, {rate_fmt}]'
        )
    else:
        pbar = None
        print(f"\n{Colors.CYAN}в–¶ Starting parallel processing...{Colors.RESET}\n")
    
    with ThreadPoolExecutor(max_workers=config.max_workers) as executor:
        future_to_file = {
            executor.submit(process_single_image, path, model, config): path
            for path in files
        }
        
        completed = 0
        
        for future in as_completed(future_to_file):
            try:
                res = future.result()
                completed += 1
                metrics.processed += 1
                
                if res:
                    results.append(res)
                    metrics.successful += 1
                else:
                    metrics.skipped += 1
                
                if pbar:
                    pbar.update(1)
                    pbar.set_postfix({
                        'OK': f"{metrics.success_rate:.0f}%",
                        'Speed': f"{metrics.images_per_second:.1f}/s"
                    })
                elif completed % 10 == 0 or completed == total:
                    percentage = (completed / total) * 100
                    bar_width = 40
                    filled = int(bar_width * completed / total)
                    bar = f"{Colors.GREEN}{'в–Ҳ' * filled}{Colors.DIM}{'в–‘' * (bar_width - filled)}{Colors.RESET}"
                    
                    print(f"\r  в”Ӯ{bar}в”Ӯ {percentage:5.1f}% ({completed}/{total}) "
                          f"в”Ӯ {Colors.GREEN}вң“{metrics.successful}{Colors.RESET} "
                          f"в”Ӯ {Colors.YELLOW}в—Ӣ{metrics.skipped}{Colors.RESET} "
                          f"в”Ӯ {metrics.images_per_second:.1f} img/s", end='', flush=True)
                    
            except Exception as e:
                metrics.failed += 1
                logger.error(f"Thread Error: {e}")
    
    if pbar:
        pbar.close()
    else:
        print()
    
    return results

