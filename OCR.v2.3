# в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

def run_pipeline(config: OCRConfig):
    """Main pipeline - Windows optimized with enhanced UI"""
    print_banner()
    print_system_info()
    print_config_summary(config)
    
    print(f"{Colors.CYAN}в–¶ Initializing Gemini API...{Colors.RESET}")
    genai.configure(api_key=config.api_key)
    
    try:
        model = genai.GenerativeModel(config.model_name)
        print(f"  {Colors.GREEN}вң“{Colors.RESET} Model loaded successfully\n")
    except Exception as e:
        logger.critical(f"Model Init Error: {e}")
        return
    
    # Check folder
    if not os.path.exists(config.image_folder):
        logger.critical(f"Folder missing: {config.image_folder}")
        print(f"\n{Colors.RED}вң– ERROR:{Colors.RESET} Image folder not found!")
        print(f"  Expected: {config.image_folder}")
        print(f"\n  {Colors.YELLOW}Tip:{Colors.RESET} Create the folder and add your subtitle images.")
        return
    
    # Collect images
    image_files = [
        os.path.join(config.image_folder, f)
        for f in os.listdir(config.image_folder)
        if f.lower().endswith(('.png', '.jpg', '.jpeg'))
    ]
    
    if not image_files:
        logger.warning("No images found!")
        print(f"\n{Colors.YELLOW}вҡ  WARNING:{Colors.RESET} No images found in folder!")
        print(f"  Supported formats: .png, .jpg, .jpeg")
        return
    
    print(f"{Colors.CYAN}в–¶ Found {Colors.BRIGHT_WHITE}{len(image_files)}{Colors.RESET}{Colors.CYAN} images{Colors.RESET}")
    print(f"{Colors.CYAN}в–¶ Starting parallel processing with {Colors.BRIGHT_WHITE}{config.max_workers}{Colors.RESET}{Colors.CYAN} workers...{Colors.RESET}\n")
    
    # Process with metrics
    metrics = PerformanceMetrics(total_images=len(image_files))
    results = process_images_parallel(image_files, model, config, metrics)
    
    print(f"\n{Colors.CYAN}в–¶ Sorting entries...{Colors.RESET}")
    print(f"{Colors.CYAN}в–¶ Merge step is disabled in v{APP_VERSION} (raw OCR entries are preserved).{Colors.RESET}")

    # Keep OCR entries as-is (no merge step)
    results.sort(key=lambda x: x[0])
    final_results = results
    
    # Generate SRT with BOM option
    print(f"{Colors.CYAN}в–¶ Generating SRT file...{Colors.RESET}")
    output_file = os.path.join(config.image_folder, config.output_filename)
    generate_srt(final_results, output_file, use_bom=config.use_bom)
    
    # Print final report
    print_final_report(metrics, len(final_results), config)
    
    # Final success message
    print(f"{Colors.BRIGHT_GREEN}в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ{Colors.RESET}")
    print(f"{Colors.BRIGHT_GREEN}   вң“ OCR PIPELINE COMPLETED SUCCESSFULLY!{Colors.RESET}")
    print(f"{Colors.BRIGHT_GREEN}   Output: {Colors.WHITE}{output_file}{Colors.RESET}")
    print(f"{Colors.BRIGHT_GREEN}в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ{Colors.RESET}")
    print()

# в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
# CLI - Windows optimized with all options
# в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

def main():
    parser = argparse.ArgumentParser(
        description=f'Professional Arabic OCR Pipeline v{APP_VERSION} - Windows Edition',
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=f"""
в•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—
в•‘  EXAMPLES                                                                    в•‘
в• в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•Ј
в•‘                                                                              в•‘
в•‘  Basic usage (auto-tuned settings):                                          в•‘
в•‘    python ocr_windows.py                                                     в•‘
в•‘                                                                              в•‘
в•‘  Custom folder:                                                              в•‘
в•‘    python ocr_windows.py --folder "C:\\Users\\Me\\Downloads\\subtitles"        в•‘
в•‘                                                                              в•‘
в•‘  High performance (more workers, larger cache):                              в•‘
в•‘    python ocr_windows.py --workers 10 --cache-size 200                       в•‘
в•‘                                                                              в•‘
в•‘  Without BOM (for non-Windows use):                                          в•‘
в•‘    python ocr_windows.py --no-bom                                            в•‘
в•‘                                                                              в•‘
в•‘  Verbose mode with custom output:                                            в•‘
в•‘    python ocr_windows.py -v --output my_subtitles.srt                        в•‘
в•‘                                                                              в•‘
в• в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•Ј
в•‘  AUTO-TUNED DEFAULTS (based on your system):                                 в•‘
в•‘    Workers: {DEFAULT_WORKERS:<4} в”Ӯ Cache: {DEFAULT_CACHE_SIZE:<4} images в”Ӯ Encoding: UTF-8 with BOM       в•‘
в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ
        """
    )
    
    # API & Model
    parser.add_argument('--api-key', 
                        help='Gemini API key (or set GEMINI_API_KEY env var)')
    
    # Paths
    parser.add_argument('--folder', default=get_default_folder(),
                        help=f'Image folder path (default: Downloads\\subtitle_images)')
    parser.add_argument('--output', default='final_subs_gemini3.srt',
                        help='Output SRT filename (default: final_subs_gemini3.srt)')
    
    # Performance tuning
    parser.add_argument('--workers', type=int, default=DEFAULT_WORKERS,
                        help=f'Parallel workers (default: {DEFAULT_WORKERS}, auto-tuned for your CPU)')
    parser.add_argument('--cache-size', type=int, default=DEFAULT_CACHE_SIZE,
                        help=f'Image cache size (default: {DEFAULT_CACHE_SIZE}, auto-tuned for your RAM)')
    parser.add_argument('--no-cache', action='store_true',
                        help='Disable image caching')
    parser.add_argument('--gap-tolerance', type=float, default=None,
                        help='[Deprecated in v2.3] Merge tolerance is ignored because merge is disabled')
    
    # Encoding
    parser.add_argument('--no-bom', action='store_true',
                        help='Disable UTF-8 BOM (not recommended for Windows Arabic)')
    
    # Display
    parser.add_argument('--no-color', action='store_true',
                        help='Disable colored output')
    parser.add_argument('--verbose', '-v', action='store_true',
                        help='Verbose logging')
    
    args = parser.parse_args()
    
    # Handle color disable
    if args.no_color:
        Colors.disable()
    
    global logger
    logger = setup_logging(args.verbose)
    
    # Build config with all options
    config = OCRConfig.from_env(
        api_key=args.api_key,
        image_folder=args.folder,
        output_filename=args.output,
        max_workers=args.workers,
        preserve_raw_entries=True,
        enable_caching=not args.no_cache,
        cache_size=args.cache_size,
        use_bom=not args.no_bom
    )

    if args.gap_tolerance is not None:
        print(f"{Colors.YELLOW}вҡ  Note:{Colors.RESET} --gap-tolerance is deprecated in v{APP_VERSION} and is currently ignored.")
    
    try:
        run_pipeline(config)
        sys.exit(0)  # Ensure clean exit on Windows (SDK may keep background threads)
    except KeyboardInterrupt:
        print(f"\n\n{Colors.YELLOW}вҡ  Interrupted by user (Ctrl+C){Colors.RESET}")
        sys.exit(130)
    except Exception as e:
        logger.critical(f"Fatal error: {e}", exc_info=args.verbose)
        print(f"\n{Colors.RED}вң– FATAL ERROR:{Colors.RESET} {e}")
        sys.exit(1)

if __name__ == "__main__":
    main()
