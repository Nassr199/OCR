# OCR PROCESSING - ORIGINAL LOGIC PRESERVED EXACTLY
# в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

@retry(
    wait=wait_random_exponential(multiplier=1, min=2, max=20),
    stop=stop_never,
    retry=retry_if_exception_type(RETRY_EXCEPTIONS),
    before_sleep=before_sleep_log(logger, logging.WARNING)
)
def perform_ocr(model, image_path: str, use_cache: bool = True) -> str:
    """ORIGINAL OCR LOGIC - PRESERVED EXACTLY"""
    img = load_image(image_path, use_cache)
    
    response = model.generate_content(
        [SYSTEM_PROMPT, img],
        safety_settings=SAFETY_SETTINGS,
        generation_config=GENERATION_CONFIG
    )
    
    return response.text

def process_single_image(file_path: str, model, config: OCRConfig):
    """ORIGINAL PROCESSING LOGIC - PRESERVED EXACTLY"""
    try:
        filename = os.path.basename(file_path)
        start, end = parse_timestamp_from_filename(filename)
        
        if start is None:
            return None
        
        raw_text = perform_ocr(model, file_path, config.enable_caching)
        final_text = clean_ocr_output(raw_text)
        
        if not final_text:
            return None
        
        # Ignore results containing only quotes/symbols - not real subtitles
        clean_check = final_text.strip()
        if clean_check == '""' or clean_check == "''":
            return None
        if re.match(r'^[\s"\'()\[\]{}ШҢ.,:;!?Шҹ\-_]+$', clean_check):
            return None
        
        # Log first 30 chars - original logic
        log_text = final_text.replace('\n', ' ')
        logger.info(f"Extracted ({filename}): {log_text[:30]}...")
        
        return (start, end, final_text)
        
    except Exception as e:
        logger.error(f"Error processing {file_path}: {e}")
        return None

