@lru_cache(maxsize=2048)
def format_timestamp(seconds: float) -> str:
    """Original logic - cached for performance"""
    hours = int(seconds // 3600)
    minutes = int((seconds % 3600) // 60)
    secs = int(seconds % 60)
    milliseconds = int((seconds - int(seconds)) * 1000)
    return f"{hours:02d}:{minutes:02d}:{secs:02d},{milliseconds:03d}"

def parse_timestamp_from_filename(filename: str) -> Tuple[Optional[float], Optional[float]]:
    """Original logic preserved EXACTLY"""
    match = re.search(r'(\d_\d{2}_\d{2}_\d{3})__(\d_\d{2}_\d{2}_\d{3})', filename)
    if match:
        try:
            def _to_sec(t_str):
                parts = list(map(int, t_str.split('_')))
                return parts[0]*3600 + parts[1]*60 + parts[2] + parts[3]/1000
            return _to_sec(match.group(1)), _to_sec(match.group(2))
        except ValueError:
            return None, None
    return None, None

def clean_ocr_output(text: str) -> str:
    """
    в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
    ORIGINAL CLEANING LOGIC - PRESERVED EXACTLY - DO NOT MODIFY!
    в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ
    """
    # Check no-text phrases - original logic
    for phrase in NO_TEXT_PHRASES:
        if phrase in text:
            return ""
    
    # Handle JSON responses - original logic
    if 'json' in text.lower() and ('{' in text or '[' in text):
        try:
            json_data = json.loads(text.strip('` \n'))
            if isinstance(json_data, dict) and 'text_content' in json_data:
                text = json_data['text'] if 'text' in json_data else json_data.get('text_content', text)
            elif isinstance(json_data, list) and len(json_data) > 0 and isinstance(json_data[0], dict) and 'label' in json_data[0]:
                text = ' '.join([d['label'] for d in json_data if 'label' in d])
            else:
                text = ''
        except json.JSONDecodeError:
            match = re.search(r'"text_content":\s*"([^"]*)"', text)
            if match:
                text = match.group(1)
            else:
                text = re.sub(r'{[^}]*}', '', text)
                text = re.sub(r'\[[^\]]*\]', '', text)
    
    # Remove code blocks - original logic
    text = re.sub(r'```.*?```', '', text, flags=re.DOTALL)
    
    # Remove BOM (Byte Order Mark) - fixes empty lines with п»ҝ
    text = text.replace('\ufeff', '').replace('\ufffe', '')
    
    # Filter disallowed characters - ORIGINAL PATTERN
    cleaned_text = DISALLOWED_CHARS_PATTERN.sub('', text)
    
    # === Original Multiline Fix - PRESERVED EXACTLY ===
    cleaned_lines = []
    for line in cleaned_text.split('\n'):
        line = line.strip().replace('\r', '')
        if line:
            cleaned_lines.append(line)
    
    return "\n".join(cleaned_lines)

def format_time(seconds: float) -> str:
    """Helper for time display"""
    if seconds < 60:
        return f"{seconds:.1f}s"
    m = int(seconds // 60)
    s = int(seconds % 60)
    return f"{m}m {s}s"

