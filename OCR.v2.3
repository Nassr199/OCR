DEFAULT_API_KEY = ""

# Windows default path
def get_default_folder():
    """Get default subtitle images folder for Windows"""
    downloads = os.path.join(os.path.expanduser('~'), 'Downloads')
    return os.path.join(downloads, 'subtitle_images')

# Auto-tuned defaults based on system
DEFAULT_WORKERS = SYSTEM_INFO.get_optimal_workers()
DEFAULT_CACHE_SIZE = SYSTEM_INFO.get_optimal_cache_size()

@dataclass
class PerformanceMetrics:
    """Real-time performance tracking"""
    total_images: int = 0
    processed: int = 0
    successful: int = 0
    failed: int = 0
    skipped: int = 0
    start_time: float = field(default_factory=time.time)
    
    @property
    def elapsed_time(self) -> float:
        return time.time() - self.start_time
    
    @property
    def images_per_second(self) -> float:
        return self.processed / self.elapsed_time if self.elapsed_time > 0 else 0
    
    @property
    def success_rate(self) -> float:
        return (self.successful / self.processed * 100) if self.processed > 0 else 0

@dataclass
class OCRConfig:
    """Pipeline configuration with Windows auto-tuning"""
    api_key: str
    model_name: str = "models/gemini-3-flash-preview"
    image_folder: str = field(default_factory=get_default_folder)
    output_filename: str = "final_subs_gemini3.srt"
    max_workers: int = field(default_factory=lambda: DEFAULT_WORKERS)
    temperature: float = 0.0
    preserve_raw_entries: bool = True
    enable_caching: bool = True
    cache_size: int = field(default_factory=lambda: DEFAULT_CACHE_SIZE)
    use_bom: bool = True  # UTF-8 with BOM for Windows Arabic compatibility
    
    @classmethod
    def from_env(cls, **kwargs):
        api_key = os.getenv('GEMINI_API_KEY') or kwargs.get('api_key') or DEFAULT_API_KEY
        return cls(api_key=api_key, **{k: v for k, v in kwargs.items() if k != 'api_key'})

