# SRT GENERATION - With UTF-8 BOM support for Windows Arabic compatibility
# в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

# UTF-8 BOM (Byte Order Mark) - Required for Windows Arabic programs
UTF8_BOM = '\ufeff'

def generate_srt(entries, output_path: str, use_bom: bool = True):
    """
    Generate SRT with safe atomic write
    
    ORIGINAL LOGIC PRESERVED - only added BOM option for Windows compatibility
    
    Args:
        entries: List of (start, end, text) tuples
        output_path: Output file path
        use_bom: If True, write UTF-8 with BOM (recommended for Windows Arabic)
    """
    temp = f"{output_path}.tmp"
    try:
        with open(temp, 'w', encoding='utf-8') as f:
            # Write BOM at the beginning for Windows Arabic compatibility
            if use_bom:
                f.write(UTF8_BOM)
            
            # Original SRT generation logic - PRESERVED EXACTLY
            for i, (start, end, text) in enumerate(entries):
                f.write(f"{i+1}\n")
                f.write(f"{format_timestamp(start)} --> {format_timestamp(end)}\n")
                f.write(f"{text}\n\n")
        
        os.replace(temp, output_path)
        
        encoding_info = "UTF-8 with BOM" if use_bom else "UTF-8"
        logger.info(f"{Colors.GREEN}вң“ SUCCESS!{Colors.RESET} Saved to: {output_path} ({encoding_info})")
        
    except Exception as e:
        if os.path.exists(temp):
            os.remove(temp)
        logger.critical(f"Save Error: {e}")
        raise

