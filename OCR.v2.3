# в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

class WindowsSystemInfo:
    """Detect Windows system capabilities for optimal configuration"""
    
    def __init__(self):
        self._cpu_count = None
        self._total_ram_gb = None
        self._is_windows = platform.system() == 'Windows'
    
    @property
    def cpu_count(self) -> int:
        """Get number of CPU cores"""
        if self._cpu_count is None:
            try:
                self._cpu_count = os.cpu_count() or 4
            except Exception:
                self._cpu_count = 4
        return self._cpu_count
    
    @property
    def total_ram_gb(self) -> float:
        """Get total RAM in GB"""
        if self._total_ram_gb is None:
            try:
                if self._is_windows:
                    # Windows-specific RAM detection
                    kernel32 = ctypes.windll.kernel32
                    c_ulonglong = ctypes.c_ulonglong
                    
                    class MEMORYSTATUSEX(ctypes.Structure):
                        _fields_ = [
                            ('dwLength', ctypes.c_ulong),
                            ('dwMemoryLoad', ctypes.c_ulong),
                            ('ullTotalPhys', c_ulonglong),
                            ('ullAvailPhys', c_ulonglong),
                            ('ullTotalPageFile', c_ulonglong),
                            ('ullAvailPageFile', c_ulonglong),
                            ('ullTotalVirtual', c_ulonglong),
                            ('ullAvailVirtual', c_ulonglong),
                            ('ullAvailExtendedVirtual', c_ulonglong),
                        ]
                    
                    mem_status = MEMORYSTATUSEX()
                    mem_status.dwLength = ctypes.sizeof(MEMORYSTATUSEX)
                    kernel32.GlobalMemoryStatusEx(ctypes.byref(mem_status))
                    self._total_ram_gb = mem_status.ullTotalPhys / (1024 ** 3)
                else:
                    # Fallback for non-Windows
                    self._total_ram_gb = 8.0
            except Exception:
                self._total_ram_gb = 8.0
        return self._total_ram_gb
    
    @property
    def available_ram_gb(self) -> float:
        """Get available RAM in GB"""
        try:
            if self._is_windows:
                kernel32 = ctypes.windll.kernel32
                c_ulonglong = ctypes.c_ulonglong
                
                class MEMORYSTATUSEX(ctypes.Structure):
                    _fields_ = [
                        ('dwLength', ctypes.c_ulong),
                        ('dwMemoryLoad', ctypes.c_ulong),
                        ('ullTotalPhys', c_ulonglong),
                        ('ullAvailPhys', c_ulonglong),
                        ('ullTotalPageFile', c_ulonglong),
                        ('ullAvailPageFile', c_ulonglong),
                        ('ullTotalVirtual', c_ulonglong),
                        ('ullAvailVirtual', c_ulonglong),
                        ('ullAvailExtendedVirtual', c_ulonglong),
                    ]
                
                mem_status = MEMORYSTATUSEX()
                mem_status.dwLength = ctypes.sizeof(MEMORYSTATUSEX)
                kernel32.GlobalMemoryStatusEx(ctypes.byref(mem_status))
                return mem_status.ullAvailPhys / (1024 ** 3)
            else:
                return 4.0
        except Exception:
            return 4.0
    
    def get_optimal_workers(self) -> int:
        """Calculate optimal number of workers based on CPU"""
        # Use CPU count - 1 to leave one core for system
        # Minimum 2, maximum 12 (API rate limiting consideration)
        optimal = max(2, min(self.cpu_count - 1, 12))
        return optimal
    
    def get_optimal_cache_size(self) -> int:
        """Calculate optimal cache size based on available RAM"""
        # Estimate: each cached image ~5MB average
        # Use 10% of available RAM for cache
        available_gb = self.available_ram_gb
        
        if available_gb >= 16:
            return 200  # High RAM: large cache
        elif available_gb >= 8:
            return 150  # Medium RAM: medium cache
        elif available_gb >= 4:
            return 100  # Low RAM: smaller cache
        else:
            return 50   # Very low RAM: minimal cache
    
    @property
    def is_windows(self) -> bool:
        return self._is_windows
    
    @property
    def windows_version(self) -> str:
        """Get Windows version string"""
        if self._is_windows:
            try:
                return platform.version()
            except Exception:
                return "Unknown"
        return "N/A"

