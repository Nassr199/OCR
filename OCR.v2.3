# IMAGE CACHING - Thread-safe with dynamic sizing
# в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ

class ImageCache:
    """
    Thread-safe intelligent LRU cache for images
    ORIGINAL LOGIC - with configurable size
    """
    def __init__(self, max_size=None):
        self.cache = {}
        self.max_size = max_size or DEFAULT_CACHE_SIZE
        self.access = {}
        self.hits = self.misses = 0
        self._lock = threading.Lock()
    
    def get(self, path):
        """Thread-safe get operation - ORIGINAL LOGIC"""
        with self._lock:
            if path in self.cache:
                self.access[path] += 1
                self.hits += 1
                return self.cache[path].copy()
            self.misses += 1
            return None
    
    def put(self, path, img):
        """Thread-safe put operation - ORIGINAL LOGIC"""
        with self._lock:
            if len(self.cache) >= self.max_size:
                if self.access:
                    lru = min(self.access.items(), key=lambda x: x[1])[0]
                    del self.cache[lru]
                    del self.access[lru]
            
            self.cache[path] = img.copy()
            self.access[path] = 1
    
    def resize(self, new_size: int):
        """Resize cache (for dynamic adjustment)"""
        with self._lock:
            self.max_size = new_size
            # Evict if over new size
            while len(self.cache) > self.max_size and self.access:
                lru = min(self.access.items(), key=lambda x: x[1])[0]
                del self.cache[lru]
                del self.access[lru]
    
    @property
    def hit_rate(self):
        """Calculate cache hit rate"""
        total = self.hits + self.misses
        return (self.hits / total * 100) if total > 0 else 0

# Global cache instance with auto-tuned size
image_cache = ImageCache(max_size=DEFAULT_CACHE_SIZE)

def load_image(path: str, use_cache=True):
    """Thread-safe image loading - ORIGINAL LOGIC"""
    if use_cache:
        cached = image_cache.get(path)
        if cached:
            return cached
    
    img = Image.open(path)
    
    if use_cache:
        image_cache.put(path, img)
    
    return img

